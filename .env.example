# Bu dosyayı kopyalayın: cp .env.example .env
# Sonra .env içindeki değerleri doldurun.
# .env dosyasını asla git'e commit etmeyin!

# Zorunlu: Uzun ve rastgele bir değer. Üretmek için:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Geliştirme ortamı için True, üretim için False
DEBUG=True

# Geliştirme ortamı için boş bırakabilirsiniz
ALLOWED_HOSTS=127.0.0.1,localhost

# Veritabanı — boş bırakılırsa SQLite kullanılır
# DATABASE_URL=postgres://user:pass@localhost:5432/aura

# E-posta (geliştirmede console backend kullanılır, doldurmak gerekmez)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=
